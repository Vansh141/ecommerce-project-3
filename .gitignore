# ── Node ─────────────────────────────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ── Environment variables (NEVER commit secrets) ──────────────────────────────
.env
.env.*
!.env.example

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
frontend/dist/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Uploads (user-generated files, should not be committed) ───────────────────
backend/uploads/

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Misc ──────────────────────────────────────────────────────────────────────
*.local
*.tgz
.npm
